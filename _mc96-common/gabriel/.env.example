# GABRIEL — environment template
# Copy to .env and fill in values. .env is gitignored.

# ── REQUIRED ──────────────────────────────────────────────────
# Anthropic API key — powers Claude calls (Haiku, Sonnet, Opus)
ANTHROPIC_API_KEY=

# NOIZY Heaven auth — used by heaven-mcp, consent-oracle, engr-keith-mcp
NOIZY_API_KEY=

# ── OPTIONAL ──────────────────────────────────────────────────
# Model routing defaults (overridable per call)
GABRIEL_DEFAULT_MODEL=claude-sonnet-4-6
GABRIEL_FAST_MODEL=claude-haiku-4-5-20251001
GABRIEL_HEAVY_MODEL=claude-opus-4-7

# Daemon binding
GABRIEL_PORT=9777
GABRIEL_BIND=127.0.0.1

# Safety: daily spend cap (USD). Daemon warns at 80%, hard-stops at 100%.
GABRIEL_DAILY_BUDGET_USD=20

# Target date for "days remaining" math in boot greeting
GABRIEL_TARGET_DATE=2026-05-17
GABRIEL_TARGET_LABEL="noizy.ai fully assembled on Cloudflare"

# Paths (override only if you move things)
NOIZY_EMPIRE_ROOT=/Users/m2ultra/NOIZYANTHROPIC
GABRIEL_MEMORY_DIR=/Users/m2ultra/.claude/projects/-Users-m2ultra-NOIZYANTHROPIC/memory
